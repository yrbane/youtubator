{
  "name": "youtubator",
  "version": "0.11.2",
  "private": true,
  "description": "Table de mixage DJ dans le navigateur, dont les platines sont des players YouTube",
  "license": "MIT",
  "author": "yrbane",
  "repository": {
    "type": "git",
    "url": "https://github.com/yrbane/youtubator.git"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "pnpm --filter @youtubator/web dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
